<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>HeartBeat</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <!-- HealthKit -->
    <key>NSHealthShareUsageDescription</key>
    <string>HeartBeat reads heart rate, HRV, resting heart rate, sleep analysis, irregular rhythm events, steps, and active energy to help monitor Long QT risk factors during activity, stress, and sleep.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>HeartBeat writes simulated health data in debug mode for testing purposes.</string>
    <!-- Background delivery via HealthKit observer queries -->
    <key>UIBackgroundModes</key>
    <array>
        <string>workout-processing</string>
        <string>remote-notification</string>
    </array>
    <key>WKApplication</key>
    <true/>
    <key>WKWatchOnly</key>
    <true/>
</dict>
</plist>
