generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String               @id @default(uuid()) @db.Uuid
  supabaseId        String               @unique @map("supabase_id")
  email             String
  genotype          String?
  onboarded         Boolean              @default(false)
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  firstName         String?              @map("first_name")
  lastName          String?              @map("last_name")
  apiTokens         ApiToken[]
  conversations     conversations[]
  doctorPrepDocs    DoctorPrepDocument[]
  emergencyContacts EmergencyContact[]
  healthAlerts      HealthAlert[]
  healthMetrics     HealthMetric[]
  medications       Medication[]
  scanLogs          ScanLog[]
  sharedCards       SharedEmergencyCard?
  watchDevice       WatchDevice?

  @@map("users")
}

model Medication {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  genericName String   @map("generic_name")
  brandName   String?  @map("brand_name")
  dosage      String?
  frequency   String?
  qtRisk      String   @map("qt_risk")
  isDTA       Boolean  @default(false) @map("is_dta")
  cypData     Json?    @map("cyp_data")
  active      Boolean  @default(true)
  addedAt     DateTime @default(now()) @map("added_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("medications")
}

model ScanLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  drugName     String   @map("drug_name")
  genericName  String   @map("generic_name")
  riskCategory String   @map("risk_category")
  comboRisk    String?  @map("combo_risk")
  scanType     String   @map("scan_type")
  alternatives Json?
  fullResult   Json?    @map("full_result")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("scan_logs")
}

model EmergencyContact {
  id           String  @id @default(uuid()) @db.Uuid
  userId       String  @map("user_id") @db.Uuid
  name         String
  phone        String
  relationship String
  email        String?
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("emergency_contacts")
}

model NotificationLog {
  id        String   @id @default(uuid()) @db.Uuid
  alertId   String   @map("alert_id") @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  channel   String
  status    String
  error     String?
  sentAt    DateTime @default(now()) @map("sent_at")

  @@index([alertId])
  @@map("notification_logs")
}

model SharedEmergencyCard {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  slug      String   @unique
  cardData  Json     @map("card_data")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shared_emergency_cards")
}

model DoctorPrepDocument {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  doctorSpecialty String   @map("doctor_specialty")
  customSpecialty String?  @map("custom_specialty")
  language        String
  customLanguage  String?  @map("custom_language")
  documentData    Json     @map("document_data")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("doctor_prep_documents")
}

model HealthMetric {
  id              String   @id @default(uuid()) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  activeEnergy    Float    @map("active_energy")
  heartRate       Float    @map("heart_rate")
  hrv             Float
  irregularRhythm Boolean  @map("irregular_rhythm")
  isAsleep        Boolean  @map("is_asleep")
  recordedAt      DateTime @map("recorded_at")
  restingHR       Float    @map("resting_hr")
  riskLevel       String   @map("risk_level")
  rrIntervalMs    Float    @map("rr_interval_ms")
  steps           Float
  stressLevel     String   @map("stress_level")
  userId          String   @map("user_id") @db.Uuid
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@index([userId, riskLevel])
  @@map("health_metrics")
}

model HealthAlert {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  riskLevel        String   @map("risk_level")
  heartRate        Float    @map("heart_rate")
  hrv              Float
  stressLevel      String   @map("stress_level")
  isAsleep         Boolean  @map("is_asleep")
  irregularRhythm  Boolean  @map("irregular_rhythm")
  message          String
  acknowledged     Boolean  @default(false)
  notifiedContacts Boolean  @default(false) @map("notified_contacts")
  triggeredAt      DateTime @map("triggered_at")
  createdAt        DateTime @default(now()) @map("created_at")
  latitude         Float?
  longitude        Float?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, triggeredAt])
  @@map("health_alerts")
}

model WatchDevice {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  apnsToken      String?  @map("apns_token")
  monitoringMode String   @default("normal") @map("monitoring_mode")
  lastSeen       DateTime @map("last_seen")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("watch_devices")
}

model ApiToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  label     String    @default("watch")
  lastUsed  DateTime? @map("last_used")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_tokens")
}

model BgDrug {
  id        String  @id @default(uuid()) @db.Uuid
  inn       String
  brandName String  @map("brand_name")
  atcCode   String? @map("atc_code")

  @@index([brandName])
  @@index([inn])
  @@map("bg_drugs")
}

model PairingCode {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  code      String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([code])
  @@map("pairing_codes")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chat_messages {
  id              String        @id @db.Uuid
  conversation_id String        @db.Uuid
  role            String
  content         String
  tool_data       Json?
  created_at      DateTime      @default(now())
  conversations   conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model conversations {
  id            String          @id @db.Uuid
  user_id       String          @db.Uuid
  title         String?
  created_at    DateTime        @default(now())
  updated_at    DateTime
  chat_messages chat_messages[]
  users         User            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, updated_at(sort: Desc)])
}
